{% extends 'base.html' %}
{% block title %}Exam & Question Bank Pro{% endblock %}

{% block content %}
<style>
:root{--qb-card:#fff;--qb-ink:#0b1120;--qb-muted:#8892a4;--qb-border:#e4e8f2;--qb-accent:#2563eb;--qb-accent2:#7c3aed;}
[data-bs-theme="dark"]{--qb-card:#1e293b;--qb-ink:#f1f5f9;--qb-muted:#94a3b8;--qb-border:#334155;}
.qb-wrap{max-width:900px;margin:0 auto;padding:1rem 0;}
.qb-card{background:var(--qb-card);border:1px solid var(--qb-border);border-radius:14px;overflow:hidden;margin-bottom:1rem;}
.qb-head{padding:1rem 1.3rem;border-bottom:1px solid var(--qb-border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.5rem;}
.qb-head h2{margin:0;font-size:1.1rem;font-weight:800;color:var(--qb-ink);}
.qb-body{padding:1.2rem 1.3rem;}
.qb-grid{display:grid;grid-template-columns:1fr 1fr;gap:.6rem;}
@media(max-width:640px){.qb-grid{grid-template-columns:1fr;}}
.qb-full{grid-column:span 2;}@media(max-width:640px){.qb-full{grid-column:span 1;}}
.qb-label{display:block;font-size:.72rem;font-weight:700;color:var(--qb-muted);text-transform:uppercase;margin-bottom:.2rem;}
.qb-input,.qb-select,.qb-textarea{width:100%;padding:.45rem .65rem;border:1px solid var(--qb-border);border-radius:8px;font-size:.84rem;background:var(--qb-card);color:var(--qb-ink);}
.qb-textarea{min-height:80px;resize:vertical;}
.qb-input:focus,.qb-select:focus,.qb-textarea:focus{border-color:var(--qb-accent);outline:none;}
.qb-btn{padding:.5rem 1.2rem;border-radius:8px;font-size:.85rem;font-weight:700;border:none;cursor:pointer;transition:transform .1s;}
.qb-btn:active{transform:scale(.97);}
.qb-btn-ai{background:linear-gradient(135deg,#2563eb,#7c3aed);color:#fff;}
.qb-btn-save{background:#10b981;color:#fff;}
.qb-btn-outline{background:transparent;border:1px solid var(--qb-border);color:var(--qb-ink);}
.qb-btn-sm{padding:.3rem .7rem;font-size:.78rem;}
.qb-btn-paper{background:linear-gradient(135deg,#f59e0b,#ef4444);color:#fff;}
.qb-q-item{border:1px solid var(--qb-border);border-radius:12px;padding:.8rem 1rem;margin-bottom:.5rem;background:var(--qb-card);transition:box-shadow .15s;}
.qb-q-item:hover{box-shadow:0 4px 12px rgba(0,0,0,.06);}
.qb-q-text{font-size:.88rem;font-weight:600;color:var(--qb-ink);margin-bottom:.3rem;}
.qb-q-meta{font-size:.73rem;color:var(--qb-muted);display:flex;gap:.6rem;flex-wrap:wrap;align-items:center;}
.qb-tag{display:inline-block;padding:.1rem .45rem;border-radius:5px;font-size:.7rem;font-weight:600;}
.qb-tag-easy{background:#10b98120;color:#10b981;}
.qb-tag-medium{background:#f59e0b20;color:#f59e0b;}
.qb-tag-hard{background:#ef444420;color:#ef4444;}
.qb-tag-fmt{background:#2563eb15;color:#2563eb;}
.qb-empty{padding:2rem;text-align:center;color:var(--qb-muted);font-size:.88rem;}
.qb-spinner{display:none;margin-left:.4rem;}
.qb-spinner.active{display:inline-block;animation:qbSpin 1s infinite linear;}
@keyframes qbSpin{to{transform:rotate(360deg);}}
.qb-tabs{display:flex;gap:0;border-bottom:2px solid var(--qb-border);margin-bottom:1rem;}
.qb-tab{padding:.5rem 1.2rem;font-size:.85rem;font-weight:600;color:var(--qb-muted);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;transition:all .15s;}
.qb-tab.active{color:var(--qb-accent);border-bottom-color:var(--qb-accent);}
.qb-panel{display:none;}.qb-panel.active{display:block;}
.qb-filter-row{display:flex;gap:.5rem;flex-wrap:wrap;margin-bottom:.8rem;}
.qb-paper-item{border:1px solid var(--qb-border);border-radius:12px;padding:.8rem 1rem;margin-bottom:.5rem;background:var(--qb-card);}
.qb-paper-item h4{margin:0 0 .2rem;font-size:.9rem;font-weight:700;color:var(--qb-ink);}
</style>

<div class="qb-wrap">

    {% if not has_qb_addon %}
    <div style="max-width:900px;margin:0 auto .6rem;padding:.5rem .8rem;background:linear-gradient(135deg,#2563eb10,#7c3aed10);border:1px solid #2563eb30;border-radius:10px;font-size:.78rem;display:flex;align-items:center;gap:.6rem;flex-wrap:wrap;">
      <span style="font-weight:700;color:#2563eb;"><i class="bi bi-stars"></i> Free AI</span>
      <div style="flex:1;min-width:120px;height:6px;background:#e4e8f2;border-radius:3px;overflow:hidden;">
        <div style="width:{% widthratio qb_gen_used qb_gen_limit 100 %}%;height:100%;background:linear-gradient(90deg,#2563eb,#7c3aed);border-radius:3px;"></div>
      </div>
      <span style="color:#64748b;">{{ qb_gen_used }}/{{ qb_gen_limit }} used</span>
      {% if qb_gen_remaining == 0 %}
      <a href="{% url 'teachers:teacher_store' %}" style="color:#2563eb;font-weight:600;text-decoration:none;">Get Exam & Question Bank Pro &rarr;</a>
      {% endif %}
    </div>
    {% endif %}

    <div class="qb-card">
        <div class="qb-head">
            <h2><i class="bi bi-database-check me-2" style="color:var(--qb-accent);"></i>Exam & Question Bank Pro</h2>
            <span style="font-size:.78rem;color:var(--qb-muted);">{{ questions|length }} question{{ questions|length|pluralize }}</span>
        </div>
        <div class="qb-body">
            <!-- Tabs -->
            <div class="qb-tabs">
                <div class="qb-tab active" onclick="switchTab('bank',this)"><i class="bi bi-collection me-1"></i>Question Bank</div>
                <div class="qb-tab" onclick="switchTab('add',this)"><i class="bi bi-plus-lg me-1"></i>Add Question</div>
                <div class="qb-tab" onclick="switchTab('ai',this)"><i class="bi bi-stars me-1"></i>AI Generate</div>
                <div class="qb-tab" onclick="switchTab('papers',this)"><i class="bi bi-file-earmark-text me-1"></i>Exam Papers</div>
            </div>

            <!-- Bank Panel -->
            <div class="qb-panel active" id="panel-bank">
                <form method="get" class="qb-filter-row">
                    <select name="subject" class="qb-select" style="max-width:180px;" onchange="this.form.submit()">
                        <option value="">All Subjects</option>
                        {% for s in subjects %}<option value="{{ s.id }}" {% if f_subject == s.id|stringformat:"d" %}selected{% endif %}>{{ s.name }}</option>{% endfor %}
                    </select>
                    <select name="difficulty" class="qb-select" style="max-width:140px;" onchange="this.form.submit()">
                        <option value="">All Difficulty</option>
                        <option value="easy" {% if f_difficulty == 'easy' %}selected{% endif %}>Easy</option>
                        <option value="medium" {% if f_difficulty == 'medium' %}selected{% endif %}>Medium</option>
                        <option value="hard" {% if f_difficulty == 'hard' %}selected{% endif %}>Hard</option>
                    </select>
                    <select name="format" class="qb-select" style="max-width:160px;" onchange="this.form.submit()">
                        <option value="">All Formats</option>
                        <option value="mcq" {% if f_format == 'mcq' %}selected{% endif %}>MCQ</option>
                        <option value="fill" {% if f_format == 'fill' %}selected{% endif %}>Fill in Blank</option>
                        <option value="short" {% if f_format == 'short' %}selected{% endif %}>Short Answer</option>
                        <option value="essay" {% if f_format == 'essay' %}selected{% endif %}>Essay</option>
                        <option value="truefalse" {% if f_format == 'truefalse' %}selected{% endif %}>True/False</option>
                    </select>
                </form>

                <form method="post" id="paperForm">
                    {% csrf_token %}
                    <input type="hidden" name="action" value="create_paper">
                    {% for q in questions %}
                    <div class="qb-q-item">
                        <div style="display:flex;align-items:flex-start;gap:.5rem;">
                            <input type="checkbox" name="selected_questions" value="{{ q.id }}" style="margin-top:.25rem;accent-color:var(--qb-accent);">
                            <div style="flex:1;">
                                <div class="qb-q-text">{{ q.question_text|truncatewords:30 }}</div>
                                <div class="qb-q-meta">
                                    {% if q.subject %}<span>{{ q.subject.name }}</span>{% endif %}
                                    {% if q.topic %}<span>{{ q.topic }}</span>{% endif %}
                                    <span class="qb-tag qb-tag-{{ q.difficulty }}">{{ q.get_difficulty_display }}</span>
                                    <span class="qb-tag qb-tag-fmt">{{ q.get_question_format_display }}</span>
                                </div>
                                {% if q.options %}<div style="font-size:.78rem;color:var(--qb-muted);margin-top:.2rem;">{% for o in q.options %}{{ o }}{% if not forloop.last %} · {% endif %}{% endfor %}</div>{% endif %}
                                {% if q.correct_answer %}<div style="font-size:.78rem;color:#10b981;margin-top:.15rem;"><i class="bi bi-check-circle-fill me-1"></i>{{ q.correct_answer }}</div>{% endif %}
                            </div>
                            <form method="post" style="display:inline;">{% csrf_token %}<input type="hidden" name="action" value="delete"><input type="hidden" name="q_id" value="{{ q.id }}"><button class="qb-btn qb-btn-outline qb-btn-sm" onclick="return confirm('Delete?')"><i class="bi bi-trash3"></i></button></form>
                        </div>
                    </div>
                    {% empty %}
                    <div class="qb-empty"><i class="bi bi-database" style="font-size:1.4rem;display:block;margin-bottom:.5rem;opacity:.3;"></i>No questions yet. Add manually or generate with AI.</div>
                    {% endfor %}

                    {% if questions %}
                    <div class="qb-card" style="margin-top:.8rem;">
                        <div class="qb-body">
                            <h3 style="font-size:.9rem;font-weight:700;margin:0 0 .5rem;">Assemble Exam Paper</h3>
                            <div class="qb-grid">
                                <div><label class="qb-label">Paper Title</label><input name="paper_title" class="qb-input" value="End of Term Exam" required></div>
                                <div><label class="qb-label">Duration (min)</label><input name="duration" class="qb-input" type="number" value="60"></div>
                                <div><label class="qb-label">Subject</label><select name="paper_subject" class="qb-select"><option value="">—</option>{% for s in subjects %}<option value="{{ s.id }}">{{ s.name }}</option>{% endfor %}</select></div>
                                <div><label class="qb-label">Class</label><select name="paper_class" class="qb-select"><option value="">—</option>{% for c in classes %}<option value="{{ c.id }}">{{ c.name }}</option>{% endfor %}</select></div>
                                <div class="qb-full"><label class="qb-label">Instructions</label><input name="instructions" class="qb-input" value="Answer ALL questions."></div>
                            </div>
                            <button type="submit" class="qb-btn qb-btn-paper" style="margin-top:.6rem;"><i class="bi bi-file-earmark-plus me-1"></i>Create Paper from Selected</button>
                        </div>
                    </div>
                    {% endif %}
                </form>
            </div>

            <!-- Add Question Panel -->
            <div class="qb-panel" id="panel-add">
                <form method="post">
                    {% csrf_token %}
                    <input type="hidden" name="action" value="add">
                    <div class="qb-grid">
                        <div><label class="qb-label">Subject</label><select name="subject" class="qb-select">{% for s in subjects %}<option value="{{ s.id }}">{{ s.name }}</option>{% endfor %}</select></div>
                        <div><label class="qb-label">Class</label><select name="target_class" class="qb-select"><option value="">—</option>{% for c in classes %}<option value="{{ c.id }}">{{ c.name }}</option>{% endfor %}</select></div>
                        <div><label class="qb-label">Topic</label><input name="topic" class="qb-input" placeholder="e.g. Fractions"></div>
                        <div><label class="qb-label">Format</label><select name="question_format" class="qb-select"><option value="mcq">Multiple Choice</option><option value="fill">Fill in Blank</option><option value="short">Short Answer</option><option value="essay">Essay</option><option value="truefalse">True / False</option></select></div>
                        <div><label class="qb-label">Difficulty</label><select name="difficulty" class="qb-select"><option value="easy">Easy</option><option value="medium" selected>Medium</option><option value="hard">Hard</option></select></div>
                        <div></div>
                        <div class="qb-full"><label class="qb-label">Question</label><textarea name="question_text" class="qb-textarea" required placeholder="Write the question here…"></textarea></div>
                        <div class="qb-full"><label class="qb-label">Options (one per line, for MCQ)</label><textarea name="options" class="qb-textarea" style="min-height:60px;" placeholder="A) First option&#10;B) Second option&#10;C) Third option&#10;D) Fourth option"></textarea></div>
                        <div><label class="qb-label">Correct Answer</label><input name="correct_answer" class="qb-input" placeholder="e.g. A"></div>
                        <div><label class="qb-label">Explanation</label><input name="explanation" class="qb-input" placeholder="Why this is correct"></div>
                    </div>
                    <button type="submit" class="qb-btn qb-btn-save" style="margin-top:.6rem;"><i class="bi bi-plus-lg me-1"></i>Add to Bank</button>
                </form>
            </div>

            <!-- AI Generate Panel -->
            <div class="qb-panel" id="panel-ai">
                <div class="qb-grid">
                    <div><label class="qb-label">Subject</label><select id="aiSubject" class="qb-select">{% for s in subjects %}<option value="{{ s.name }}">{{ s.name }}</option>{% endfor %}</select></div>
                    <div><label class="qb-label">Topic</label><input id="aiTopic" class="qb-input" placeholder="e.g. Photosynthesis"></div>
                    <div><label class="qb-label">Format</label><select id="aiFormat" class="qb-select"><option value="mcq">MCQ</option><option value="fill">Fill in Blank</option><option value="short">Short Answer</option><option value="truefalse">True/False</option></select></div>
                    <div><label class="qb-label">Difficulty</label><select id="aiDiff" class="qb-select"><option value="easy">Easy</option><option value="medium" selected>Medium</option><option value="hard">Hard</option></select></div>
                    <div><label class="qb-label">Number of Questions</label><input id="aiCount" class="qb-input" type="number" value="5" min="1" max="10"></div>
                </div>
                <button type="button" class="qb-btn qb-btn-ai" style="margin-top:.6rem;" onclick="generateQuestions()">
                    <i class="bi bi-stars me-1"></i>Generate Questions
                    <i class="bi bi-arrow-repeat qb-spinner" id="qbSpinner"></i>
                </button>
                <div id="aiResults" style="margin-top:.8rem;"></div>
            </div>

            <!-- Exam Papers Panel -->
            <div class="qb-panel" id="panel-papers">
                {% for p in papers %}
                <div class="qb-paper-item">
                    <h4>{{ p.title }}</h4>
                    <div class="qb-q-meta">
                        {% if p.subject %}{{ p.subject.name }} · {% endif %}{{ p.duration_minutes }} min · {{ p.questions.count }} questions · {{ p.created_at|date:"M d, Y" }}
                    </div>
                    <a href="{% url 'teachers:addon_exam_paper' %}?id={{ p.id }}" class="qb-btn qb-btn-outline qb-btn-sm" style="margin-top:.4rem;"><i class="bi bi-eye me-1"></i>View / Print</a>
                </div>
                {% empty %}
                <div class="qb-empty"><i class="bi bi-file-earmark-text" style="font-size:1.4rem;display:block;margin-bottom:.5rem;opacity:.3;"></i>No exam papers yet. Select questions from the bank and create one.</div>
                {% endfor %}
            </div>
        </div>
    </div>
</div>

<script>
function switchTab(name,el){
    document.querySelectorAll('.qb-tab').forEach(t=>t.classList.remove('active'));
    document.querySelectorAll('.qb-panel').forEach(p=>p.classList.remove('active'));
    el.classList.add('active');
    document.getElementById('panel-'+name).classList.add('active');
}

async function generateQuestions(){
    const topic=document.getElementById('aiTopic').value;
    if(!topic){alert('Enter a topic.');return;}
    const spinner=document.getElementById('qbSpinner');
    spinner.classList.add('active');
    const container=document.getElementById('aiResults');
    container.innerHTML='<div style="color:var(--qb-muted);font-size:.84rem;">Generating questions…</div>';
    try{
        const r=await fetch('{% url "teachers:question_bank_ai" %}',{
            method:'POST',
            headers:{'Content-Type':'application/json','X-CSRFToken':'{{ csrf_token }}'},
            body:JSON.stringify({
                topic,subject:document.getElementById('aiSubject').value,
                format:document.getElementById('aiFormat').value,
                difficulty:document.getElementById('aiDiff').value,
                count:document.getElementById('aiCount').value
            })
        });
        const data=await r.json();
        if(r.status===403&&data.error_code==='freemium_limit'){alert(data.message);container.innerHTML='';return;}
        if(r.status===429){alert(data.error||'Quota exceeded.');container.innerHTML='';return;}
        if(data.questions&&data.questions.length){
            let html='<div style="font-size:.82rem;font-weight:700;color:var(--qb-accent);margin-bottom:.5rem;">'+data.questions.length+' questions generated — add them to your bank:</div>';
            data.questions.forEach((q,i)=>{
                const opts=q.options||[];
                html+=`<div class="qb-q-item"><div class="qb-q-text">${i+1}. ${q.question}</div>`;
                if(opts.length)html+=`<div style="font-size:.78rem;color:var(--qb-muted);margin:.2rem 0;">${opts.join(' · ')}</div>`;
                html+=`<div style="font-size:.78rem;color:#10b981;"><i class="bi bi-check-circle-fill me-1"></i>${q.correct||'—'}</div>`;
                if(q.explanation)html+=`<div style="font-size:.75rem;color:var(--qb-muted);font-style:italic;">${q.explanation}</div>`;
                html+=`<button type="button" class="qb-btn qb-btn-save qb-btn-sm" style="margin-top:.3rem;" onclick="saveAiQuestion(this,${JSON.stringify(q).replace(/"/g,'&quot;')})"><i class="bi bi-plus-lg me-1"></i>Add to Bank</button></div>`;
            });
            container.innerHTML=html;
        }else{container.innerHTML='<div style="color:var(--qb-muted);">No questions returned.</div>';}
    }catch(e){container.innerHTML='<div style="color:#ef4444;">Error: '+e.message+'</div>';}
    spinner.classList.remove('active');
}

function saveAiQuestion(btn,q){
    const form=document.createElement('form');
    form.method='POST';form.style.display='none';
    form.innerHTML=`<input name="csrfmiddlewaretoken" value="{{ csrf_token }}"><input name="action" value="add"><input name="question_text" value="${(q.question||'').replace(/"/g,'&quot;')}"><input name="question_format" value="${document.getElementById('aiFormat').value}"><input name="difficulty" value="${document.getElementById('aiDiff').value}"><input name="topic" value="${document.getElementById('aiTopic').value}"><input name="options" value="${(q.options||[]).join('\n').replace(/"/g,'&quot;')}"><input name="correct_answer" value="${(q.correct||'').replace(/"/g,'&quot;')}"><input name="explanation" value="${(q.explanation||'').replace(/"/g,'&quot;')}">`;
    document.body.appendChild(form);form.submit();
}
</script>
{% endblock %}
