# Django Settings
# Generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-with-a-long-random-secret-key
DEBUG=True

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Cloudinary (Media Storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# OpenAI API (for AI features)
OPENAI_API_KEY=your-openai-api-key-here

# Google OAuth 2.0 (for individual user authentication)
# Get credentials from https://console.cloud.google.com/
# 1. Create/select a project
# 2. Enable Google Identity API
# 3. Create OAuth 2.0 Client ID
# 4. Add authorized redirect URI: http://localhost:8000/u/auth/google/callback/
# 5. For production, add your domain's callback URL
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# Paystack Payment Gateway
# Get keys at https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Currency for Paystack: GHS (Ghana Cedis), NGN (Nigerian Naira), KES (Kenyan Shilling), USD, etc.
PAYSTACK_CURRENCY=GHS

# Africa's Talking SMS (optional)
AT_USERNAME=sandbox
AT_API_KEY=your-africastalking-api-key

# Production Settings (Vercel/Railway)
VERCEL=1  # Set to 1 when deploying to Vercel

# Wrapper Targeting (Capacitor/Electron)
# development | staging | production
SCHOOL_PORTAL_ENV=development
# Optional explicit URL override for wrappers
SCHOOL_PORTAL_URL=http://localhost:8000
